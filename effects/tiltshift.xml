<?xml version="1.0" encoding="UTF-8" ?>
<c2effect>
	<id>tiltshift</id>
	<name>Tilt Shift</name>
	<category>Blur</category>
	<description>Vertical and Horizontal gradient blur.</description>
	<author>Gemini</author>

	<extend-box-horizontal>0</extend-box-horizontal>
	<extend-box-vertical>0</extend-box-vertical>
	<blends-background>false</blends-background>
	<cross-sampling>false</cross-sampling>
	<animated>true</animated>

	<parameters>
		<param>
			<name>Intensity</name>
			<description>Strength of the blur.</description>
			<type>float</type>
			<initial>5.0</initial>
			<uniform>blurAmount</uniform>
		</param>
		<param>
			<name>Vertical Center</name>
			<description>Y position of focus.</description>
			<type>float</type>
			<initial>0.5</initial>
			<uniform>center</uniform>
		</param>
		<param>
			<name>Vertical Spread</name>
			<description>How wide the vertical focus is.</description>
			<type>float</type>
			<initial>0.1</initial>
			<uniform>spread</uniform>
		</param>
		<param>
			<name>Horizontal Spread</name>
			<description>How wide the horizontal focus is.</description>
			<type>float</type>
			<initial>0.3</initial>
			<uniform>hSpread</uniform>
		</param>
	</parameters>
</c2effect>